# .env.production.example — Castor production env template.
#
# Copy to .env (gitignored) and fill in real values before `docker compose up`.
# Every var Castor reads at runtime is here. Group order matches base.py +
# production.py so a side-by-side diff against the settings is trivial.
#
# Local dry-run hint: a working .env for `LETSENCRYPT_DIR=./tmp/letsencrypt`
# only needs DJANGO_SECRET_KEY, POSTGRES_PASSWORD, ANTHROPIC_API_KEY (or
# leave it empty if you keep ASK_PROVIDER=ollama), DJANGO_ALLOWED_HOSTS, and
# SECURE_SSL_REDIRECT=False if you're hitting the stack over plain HTTP.

# ─── Django core ──────────────────────────────────────────────────────────
# Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=castoriq.io,www.castoriq.io
DJANGO_CSRF_TRUSTED_ORIGINS=https://castoriq.io,https://www.castoriq.io
SITE_URL=https://castoriq.io

# ─── HTTPS posture ────────────────────────────────────────────────────────
# Override only for local dry-runs over plain HTTP. Production stays True.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ─── Database (Postgres + pgvector) ───────────────────────────────────────
# Hostname `db` matches the compose service name.
POSTGRES_DB=castor
POSTGRES_USER=castor
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Email (Brevo SMTP relay) ─────────────────────────────────────────────
# Brevo's free tier is 300 emails/day — plenty for the beta. SPF + DKIM via
# Brevo's domain auth flow is recommended for deliverability but not required
# to send. Full setup walk-through: docs/business/sentry-and-email.md.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Castor <noreply@castoriq.io>
SERVER_EMAIL=Castor <noreply@castoriq.io>
# Operator inbox that gets a one-line ping for every new beta application.
# Leave blank to disable; the applicant always gets their confirmation either way.
OPERATOR_NOTIFICATION_EMAIL=

# ─── Beta funnel anti-abuse ───────────────────────────────────────────────
# Per-IP rate limit on /beta/apply/ (django-ratelimit syntax). 5/h is plenty
# for legitimate retries while killing bot abuse.
BETA_RATE_LIMIT=5/h
# Daily Brevo budget circuit breaker. At BETA_DAILY_OPERATOR_CAP, operator
# notifications stop. At BETA_DAILY_TOTAL_CAP, applicant confirmations also
# stop — keeping headroom under the 300/day free tier for password resets and
# admin welcome emails. Submissions still persist either way.
BETA_DAILY_OPERATOR_CAP=250
BETA_DAILY_TOTAL_CAP=290

# ─── Login lockout (django-axes) ──────────────────────────────────────────
# Locks /admin/ and login views per-IP after N failed attempts. Cooloff in
# hours; reset on a successful login. Leave AXES_IPWARE_PROXY_COUNT=1 in prod
# (nginx is the single ingress); set to 0 in dev so unit tests can't spoof IPs.
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
AXES_IPWARE_PROXY_COUNT=1

# ─── Ollama (CPU-only on the VPS) ─────────────────────────────────────────
# host.docker.internal works when Ollama runs on the Docker host (Linux too,
# via the extra_hosts mapping in compose). Override if Ollama lives in its
# own container.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_EMBED_BATCH_SIZE=16
OLLAMA_REQUEST_TIMEOUT=120

# ─── Cloud LLM providers ──────────────────────────────────────────────────
# Defaults seed SiteLLMConfig the first time it's read. Operator flips Ask /
# Modify between providers from the admin singleton at runtime.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
ASK_PROVIDER=ollama
ASK_MODEL=claude-sonnet-4-6
MODIFY_PROVIDER=ollama
MODIFY_MODEL=llama-3.3-70b-versatile

# Last-resort circuit-breaker. Set to 1 to refuse every cloud call and show
# the maintenance banner site-wide. Local Ollama keeps working.
LLM_MASTER_KILL=0

# ─── RAG / vector tuning ──────────────────────────────────────────────────
RAG_RESPONSE_RESERVE=1500
RAG_SAFETY_RATIO=0.90
PGVECTOR_DIMENSIONS=1024

# ─── GLM-OCR (off by default; enable per-deployment if needed) ────────────
GLM_OCR_ENABLED=False
GLM_OCR_MODEL=glm-ocr:latest
GLM_OCR_AUTO_TRIGGER=True
GLM_OCR_MAX_PAGES_AUTO=100
GLM_OCR_PAGE_DPI=150
GLM_OCR_TEXT_DENSITY_THRESHOLD=50

# ─── Upload paths (relative to MEDIA_ROOT) ────────────────────────────────
IFC_UPLOAD_DIR=uploads/ifc
DOCUMENT_UPLOAD_DIR=uploads/documents

# ─── Sentry (optional — leave SENTRY_DSN empty to disable) ────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ─── Password reset link lifetime (seconds; default 15 min) ───────────────
PASSWORD_RESET_TIMEOUT=900

# ─── Supabase (developer error-log aggregation; optional) ─────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
