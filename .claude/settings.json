{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:\\Users\\carlo\\OneDrive\\Documents\\PycharmProjects\\ZIGURAT\\Castor && uv run ruff check src/ tests/ --fix --quiet 2>&1 | head -20; uv run ruff format src/ tests/ --quiet"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cd src*)",
      "Bash(uv run*)",
      "Bash(ruff *)",
      "Bash(pytest*)",
      "Bash(git *)",
      "Bash(docker compose*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(ollama *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Read(*)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(tests/**)",
      "Write(docker/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(docker compose*down -v*)",
      "Write(.env)"
    ]
  }
}